{
  "name": "muji-hotel",
  "version": "0.1.0",
  "private": true,
  "//": "SECURITY NOTE: 13 low-severity vulnerabilities exist in min-document (Sanity transitive dependency).",
  "//2": "Vulnerability: Prototype pollution in min-document <=2.19.0 (all versions affected).",
  "//3": "Status: Using latest Sanity v4.10.2 and next-sanity v11.4.2. Awaiting upstream fix.",
  "//4": "Risk: LOW - min-document is not directly exposed in production; used internally by Sanity Studio.",
  "//5": "Action: Monitor https://github.com/advisories/GHSA-rx8g-88g5-qh64 for updates.",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS='--no-experimental-webstorage' next dev",
    "build": "cross-env NODE_OPTIONS='--no-experimental-webstorage' next build",
    "start": "cross-env NODE_OPTIONS='--no-experimental-webstorage' next start",
    "lint": "eslint .",
    "audit:check": "npm audit --audit-level=moderate",
    "audit:full": "npm audit",
    "audit:summary": "npm audit --json | node -e \"const data = JSON.parse(require('fs').readFileSync(0, 'utf-8')); console.log(`Total: ${data.metadata.vulnerabilities.total} | Info: ${data.metadata.vulnerabilities.info} | Low: ${data.metadata.vulnerabilities.low} | Moderate: ${data.metadata.vulnerabilities.moderate} | High: ${data.metadata.vulnerabilities.high} | Critical: ${data.metadata.vulnerabilities.critical}`);\""
  },
  "dependencies": {
    "@sanity/client": "^7.23.0",
    "@sanity/vision": "^6.1.0",
    "@stripe/stripe-js": "^9.8.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "fix": "^0.0.6",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "next-sanity": "^13.1.1",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "sanity": "^6.1.0",
    "stripe": "^22.2.3",
    "swr": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/event-source-polyfill": "^1.0.5",
    "@types/hast": "^3.0.4",
    "@types/node": "^26.0.0",
    "@types/normalize-package-data": "^2.4.4",
    "@types/react": "^19.2.17",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "glob": "^11.1.0",
    "undici": "^8.3.0",
    "ws": "^8.21.0",
    "jsdom": "^27.4.0",
    "uuid": "11.1.1",
    "js-yaml": "^4.1.0",
    "underscore": "^1.13.8",
    "next": {
      "postcss": "^8.5.15"
    },
    "underscore.string": "^3.3.6",
    "postcss": ""
  },
  "lavamoat": {
    "allowScripts": {
      "eslint-config-next>eslint-import-resolver-typescript>unrs-resolver": false,
      "next>sharp": false,
      "sanity>@sanity/cli>tsx>esbuild": false
    }
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
